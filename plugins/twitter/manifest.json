{
  "id": "twitter",
  "name": "Twitter/X",
  "version": "1.0.0",
  "description": "Read-only access to X/Twitter API v2 — posts, users, search, timelines, trends",
  "author": { "name": "teleton", "url": "https://github.com/TONresistor" },
